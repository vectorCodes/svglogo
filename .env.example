# Cloudflare Turnstile (public site key — client-side)
# Create a site at https://dash.cloudflare.com/?to=/:account/turnstile
# Use "Invisible" widget type
VITE_TURNSTILE_SITE_KEY=your_site_key_here

# The following are secrets — add to .dev.vars for local dev,
# deploy to production via `wrangler secret put <KEY>`:
#
# TURNSTILE_SECRET=your_turnstile_secret_here
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHAT_ID=your_telegram_chat_id_here
